<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../components/head') %>
</head>
<body>
  <%- include('../components/nav') %>

  <main class="responsive">
    <div class="space"></div>
    <h3>Contact</h3>

    <% if (submitted) { %>
      <article class="round border form-panel">
        <p>Thanks, <strong><%= name %></strong>! Your message has been received.</p>
      </article>
    <% } else { %>
      <form action="/contact" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="field label border">
          <input type="text" id="name" name="name" required>
          <label for="name">Name</label>
        </div>
        <div class="field label border">
          <input type="email" id="email" name="email" required>
          <label for="email">Email</label>
        </div>
        <div class="field label textarea border">
          <textarea id="message" name="message" rows="5" required></textarea>
          <label for="message">Message</label>
        </div>
        <div class="space"></div>
        <button type="submit">Send Message</button>
      </form>
    <% } %>

    <div class="space"></div>
    <% if (user) { %>
      <% if (messages && messages.length > 0) { %>
        <h5>Your Messages</h5>
        <div class="comment-list border round">
          <% [...messages].reverse().forEach((m, i) => { %>
            <% if (i > 0) { %><div class="divider"></div><% } %>
            <div class="padding">
              <strong><%= m.name %></strong>
              <small class="secondary-text"> · <%= m.createdAt.toLocaleString() %></small>
              <p><%= m.message %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    <% } else { %>
      <p class="secondary-text"><%= messageCount %> message<%= messageCount === 1 ? '' : 's' %> received so far.</p>
    <% } %>
  </main>

  <%- include('../components/footer') %>
</body>
</html>
